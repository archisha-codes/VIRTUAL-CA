# =============================================================================
# Virtual CA - GSTR Compliance System Configuration
# =============================================================================
# Copy this file to .env and modify the values for your environment

# =============================================================================
# Application Settings
# =============================================================================
# Environment: development, staging, production
ENV=development

# Application name and version (optional override)
APP_NAME=GSTR Compliance Backend
APP_VERSION=1.1.0

# =============================================================================
# JWT Authentication
# =============================================================================
# IMPORTANT: Change these values in production!
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24 hours (60 * 24)

# =============================================================================
# API Key for external access
# =============================================================================
GST_API_KEY=your-gst-api-key-change-in-production
API_KEY_NAME=X-API-Key

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Log directory (make sure this directory exists and is writable)
LOG_DIR=/app/logs

# =============================================================================
# File Upload Settings
# =============================================================================
# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# Upload directory (make sure this directory exists and is writable)
UPLOAD_DIR=/tmp/uploads

# Temporary directory for processing
TEMP_DIR=/tmp

# =============================================================================
# Database Configuration (Optional - for future use)
# =============================================================================
# SQLite (default, no setup required)
# DATABASE_URL=sqlite:///./gstr_data.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/gstr_db

# MySQL example:
# DATABASE_URL=mysql://user:password@localhost:3306/gstr_db

DATABASE_TYPE=sqlite

# =============================================================================
# Redis Configuration (Optional - for caching and rate limiting)
# =============================================================================
# Redis URL (leave empty if not using Redis)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CORS Settings
# =============================================================================
# Comma-separated list of allowed origins (use * for development only)
CORS_ORIGINS=*

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Frontend URL (for CORS and redirects)
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Session Settings
# =============================================================================
SESSION_SECRET_KEY=your-session-secret-key-change-in-production

# =============================================================================
# Third-party API Keys (Optional)
# =============================================================================
# GST Portal credentials (if needed for direct API access)
# GST_PORTAL_USERNAME=
# GST_PORTAL_PASSWORD=

# =============================================================================
# GST-Specific Configuration
# =============================================================================
# Default GSTIN for the taxpayer
DEFAULT_GSTIN=27AAAAA1234A1ZA

# GST Portal Token (for GSTR-2B API access)
GST_PORTAL_TOKEN=

# GST API Secret (for authentication)
GST_API_SECRET=

# Enable GST Portal sync (set to false for offline mode)
GST_PORTAL_SYNC_ENABLED=false

# =============================================================================
# Email Settings (Optional - for notifications)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com

# =============================================================================
# Security Settings
# =============================================================================
# Enable/disable certain features based on environment
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_REQUEST_LOGGING=true
